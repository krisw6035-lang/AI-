.page-container { min-height: 100vh; background: #F5F5F5; }
.scene-tabs { display: flex; background: #fff; padding: 12px 16px; gap: 20px; position: sticky; top: 0; z-index: 10; }
.tab { font-size: 15px; color: #666; padding: 4px 0; }
.tab.active { color: #2C3E50; font-weight: 600; border-bottom: 2px solid #C9A96E; }
.loading, .empty { text-align: center; padding: 60px 0; color: #999; font-size: 15px; }
.case-list { padding: 12px 16px; }
.case-card { background: #fff; border-radius: 12px; overflow: hidden; margin-bottom: 12px; }
.case-img { width: 100%; height: 200px; display: block; }
.case-info { padding: 12px 16px; }
.case-title { font-size: 16px; font-weight: 600; color: #2C3E50; margin-bottom: 8px; }
.case-meta { display: flex; gap: 8px; }
.case-tag { font-size: 12px; background: #E8F5E9; color: #388E3C; padding: 2px 8px; border-radius: 4px; }
.case-style { font-size: 12px; color: #999; }
.load-more { text-align: center; padding: 16px; }
.load-btn { display: inline-block; font-size: 14px; color: #2C3E50; padding: 8px 24px; border: 1px solid #2C3E50; border-radius: 20px; }
