/* 设计选择页面样式 */
.page-container { padding-bottom: 160rpx; background: #F8F8F6; min-height: 100vh; }

.preview-bar {
  display: flex; align-items: center; padding: 20rpx 30rpx;
  background: #2C3E50; color: #fff;
}
.preview-thumb { width: 80rpx; height: 80rpx; border-radius: 8rpx; margin-right: 16rpx; }
.preview-label { font-size: 28rpx; }

.loading-wrap { text-align: center; padding: 100rpx 0; }
.loading-text { font-size: 28rpx; color: #999; }

/* 区块 */
.section { padding: 30rpx; background: #fff; margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #2C3E50; margin-bottom: 20rpx; }
.required { color: #E74C3C; }
.tip-text { font-size: 24rpx; color: #999; font-weight: 400; }

/* 风格卡片 */
.option-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.option-card {
  width: calc(50% - 8rpx); padding: 20rpx;
  background: #F5F5F5; border-radius: 12rpx;
  border: 2rpx solid transparent; transition: all 0.2s;
}
.option-card.active { background: #EEF2F6; border-color: #2C3E50; }
.option-name { font-size: 28rpx; font-weight: 500; color: #333; margin-bottom: 6rpx; }
.option-desc { font-size: 22rpx; color: #999; line-height: 1.4; }

/* Chip 选择 */
.option-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.chip {
  padding: 12rpx 28rpx; border-radius: 30rpx;
  background: #F5F5F5; font-size: 26rpx; color: #666;
  border: 2rpx solid transparent;
}
.chip.active { background: #2C3E50; color: #fff; }

/* 颜色选择 */
.color-row { display: flex; gap: 20rpx; overflow-x: auto; }
.color-chip {
  display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 12rpx; border-radius: 12rpx;
  border: 2rpx solid transparent; min-width: 120rpx;
}
.color-chip.active { border-color: #2C3E50; background: #EEF2F6; }
.color-swatch { width: 60rpx; height: 60rpx; border-radius: 50%; margin-bottom: 8rpx; border: 1rpx solid #EEE; }
.color-label { font-size: 24rpx; color: #333; font-weight: 500; }
.color-name { font-size: 20rpx; color: #999; margin-top: 4rpx; }

/* 软装 Chip */
.soft-chip { padding: 14rpx 24rpx; }

/* 自定义输入 */
.custom-input {
  width: 100%; min-height: 120rpx; padding: 20rpx;
  background: #F8F8F6; border-radius: 12rpx; font-size: 26rpx;
  box-sizing: border-box;
}
.char-count { text-align: right; font-size: 22rpx; color: #BBB; margin-top: 8rpx; }

/* 底部栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 30rpx; background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.cost-info { display: flex; align-items: baseline; gap: 10rpx; }
.cost-label { font-size: 24rpx; color: #999; }
.cost-value { font-size: 32rpx; font-weight: 700; color: #C9A96E; }
.submit-btn {
  padding: 20rpx 40rpx; background: linear-gradient(135deg, #2C3E50, #3D5166);
  color: #fff; border-radius: 40rpx; font-size: 28rpx; font-weight: 500;
}
.submit-btn:active { opacity: 0.85; }
.submit-btn.disabled { background: #CCC; color: #999; }
