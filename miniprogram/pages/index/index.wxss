/**
 * 首页样式
 */

/* === Hero 区域 === */
.hero-section {
  background: linear-gradient(160deg, #2C3E50 0%, #3D5166 40%, #4A6A8A 100%);
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
  color: #fff;
}

.hero-brand {
  font-size: 24rpx;
  letter-spacing: 12rpx;
  opacity: 0.7;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.hero-slogan {
  font-size: 28rpx;
  opacity: 0.85;
  line-height: 1.6;
}

/* === 双入口 === */
.entry-section {
  display: flex;
  margin: -30rpx 30rpx 30rpx;
  gap: 20rpx;
}

.entry-card {
  flex: 1;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 40rpx 30rpx;
  text-align: center;
  box-shadow: var(--shadow-md);
  transition: transform 0.2s;
}

.entry-card:active {
  transform: scale(0.96);
}

.entry-indoor {
  border-top: 6rpx solid #C9A96E;
}

.entry-outdoor {
  border-top: 6rpx solid #5B8C5A;
}

.entry-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.entry-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 10rpx;
}

.entry-desc {
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}

/* === 操作流程 === */
.steps-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx 40rpx;
  gap: 16rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.step-num {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-label {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.step-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
  padding-bottom: 20rpx;
}

/* === 精选案例 === */
.cases-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  gap: 20rpx;
}

.case-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.case-card:active {
  opacity: 0.9;
}

.case-image {
  width: 100%;
  height: 260rpx;
  background: #eee;
}

.case-info {
  padding: 16rpx 20rpx 20rpx;
}

.case-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-style {
  font-size: 22rpx;
  color: var(--color-accent);
}

.more-link {
  text-align: center;
  padding: 30rpx;
  color: var(--color-primary);
  font-size: 28rpx;
}

.loading-hint,
.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  color: var(--color-text-muted);
  font-size: 26rpx;
}
