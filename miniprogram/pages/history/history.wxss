.page-container { min-height: 100vh; background: #F5F5F5; }

.user-card {
  display: flex; align-items: center; padding: 30rpx;
  background: linear-gradient(135deg, #2C3E50, #3D5166);
  margin: 20rpx; border-radius: 16rpx; color: #fff;
}
.user-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2); display: flex;
  align-items: center; justify-content: center;
  font-size: 36rpx; margin-right: 20rpx;
}
.user-name { font-size: 32rpx; font-weight: 600; margin-bottom: 8rpx; }
.user-points { font-size: 26rpx; opacity: 0.9; }
.arrow { font-size: 30rpx; margin-left: 6rpx; }

.section-title { font-size: 30rpx; font-weight: 600; color: #2C3E50; padding: 20rpx 30rpx 10rpx; }

.empty-state { text-align: center; padding: 100rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.empty-tip { font-size: 24rpx; color: #BBB; margin-top: 10rpx; }

.task-card { background: #fff; margin: 16rpx 20rpx; padding: 24rpx; border-radius: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.task-header { margin-bottom: 12rpx; }
.task-scene { font-size: 26rpx; color: #2C3E50; font-weight: 500; }
.task-body { display: flex; justify-content: space-between; align-items: center; }
.task-style { font-size: 28rpx; color: #333; }
.task-time { font-size: 22rpx; color: #BBB; }

.status-success { color: #27AE60; }
.status-fail { color: #E74C3C; }

.load-more { text-align: center; padding: 30rpx; font-size: 26rpx; color: #999; }
