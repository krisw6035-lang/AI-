.page-container { padding: 16px; background: #F5F5F5; min-height: 100vh; }
.card { background: #fff; border-radius: 12px; padding: 20px; margin-bottom: 12px; }
.card-title { font-size: 17px; font-weight: 600; color: #2C3E50; margin-bottom: 16px; }
.info-item { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #f5f5f5; }
.info-label { font-size: 14px; color: #999; }
.info-value { font-size: 14px; color: #333; }
.form-group { margin-bottom: 16px; }
.textarea { width: 100%; height: 120px; background: #f9f9f9; border-radius: 8px; padding: 12px; font-size: 14px; box-sizing: border-box; }
.char-count { text-align: right; font-size: 12px; color: #ccc; margin-top: 4px; }
.submit-btn { background: #2C3E50; color: #fff; font-size: 16px; padding: 10px; border-radius: 24px; }
.submit-btn[disabled] { background: #ccc; }
.link-item { padding: 12px 0; border-bottom: 1px solid #f5f5f5; font-size: 15px; color: #2C3E50; }
