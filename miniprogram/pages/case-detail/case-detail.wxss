.page-container { background: #F5F5F5; min-height: 100vh; }
.detail-img { width: 100%; height: 360px; background: #eee; }
.info-card { background: #fff; margin: 12px 16px; border-radius: 12px; padding: 20px; }
.detail-title { font-size: 20px; font-weight: 700; color: #2C3E50; margin-bottom: 8px; }
.detail-desc { font-size: 14px; color: #666; line-height: 1.6; margin-bottom: 16px; }
.info-row { display: flex; justify-content: space-between; padding: 10px 0; border-top: 1px solid #f0f0f0; }
.info-label { font-size: 14px; color: #999; }
.info-value { font-size: 14px; color: #2C3E50; font-weight: 500; }
.action-bar { padding: 16px; text-align: center; }
.btn-secondary { background: #fff; color: #2C3E50; border: 1px solid #ddd; padding: 10px 24px; border-radius: 24px; font-size: 15px; }
.loading { text-align: center; padding: 80px 0; color: #999; }
