.page-container { background: #F5F5F5; min-height: 100vh; padding-bottom: 32px; }
.hero-section { text-align: center; padding: 32px 16px; background: linear-gradient(135deg, #2C3E50, #34495E); color: #fff; }
.hero-title { font-size: 22px; font-weight: 700; }
.hero-desc { font-size: 14px; opacity: 0.8; margin-top: 8px; }
.card { background: #fff; border-radius: 12px; padding: 20px; margin: 12px 16px; }
.card-title { font-size: 17px; font-weight: 600; color: #2C3E50; margin-bottom: 16px; }
.style-grid { display: flex; flex-wrap: wrap; gap: 12px; }
.style-item { flex: 0 0 calc(33.33% - 8px); text-align: center; background: #f9f9f9; border-radius: 10px; padding: 16px 8px; }
.style-icon { font-size: 28px; margin-bottom: 6px; }
.style-name { font-size: 13px; color: #333; font-weight: 500; }
.style-desc { font-size: 11px; color: #999; margin-top: 4px; }
.color-grid { display: flex; flex-wrap: wrap; gap: 12px; }
.color-item { flex: 0 0 calc(20% - 10px); text-align: center; }
.color-swatch { width: 48px; height: 48px; border-radius: 50%; margin: 0 auto 6px; border: 1px solid #eee; }
.color-name { font-size: 12px; color: #666; }
.action-area { text-align: center; padding: 24px 16px; }
.cta-btn { background: #2C3E50; color: #fff; font-size: 16px; padding: 12px 32px; border-radius: 24px; }
