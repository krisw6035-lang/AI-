/* 图片上传页面样式 */
.page-container { padding: 30rpx; min-height: 100vh; background: #F8F8F6; }

.scene-header { text-align: center; padding: 40rpx 0 30rpx; }
.scene-icon { font-size: 60rpx; margin-bottom: 10rpx; }
.scene-title { font-size: 36rpx; font-weight: 600; color: #2C3E50; margin-bottom: 8rpx; }
.scene-tip { font-size: 26rpx; color: #999; }

.image-area {
  position: relative; width: 100%; height: 500rpx;
  background: #fff; border-radius: 16rpx; overflow: hidden;
  margin-bottom: 30rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.upload-placeholder {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; height: 100%;
  border: 2rpx dashed #DDD; margin: 20rpx; border-radius: 12rpx;
}
.placeholder-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.placeholder-text { font-size: 30rpx; color: #666; margin-bottom: 10rpx; }
.placeholder-tip { font-size: 24rpx; color: #BBB; }

.preview-image { width: 100%; height: 100%; }

.upload-badge {
  position: absolute; top: 16rpx; right: 16rpx;
  background: #4CAF50; color: #fff; font-size: 24rpx;
  padding: 8rpx 20rpx; border-radius: 20rpx;
}

.action-buttons { display: flex; flex-direction: column; gap: 20rpx; }
.btn-primary {
  background: #2C3E50; color: #fff; text-align: center;
  padding: 24rpx; border-radius: 12rpx; font-size: 30rpx; font-weight: 500;
}
.btn-primary:active { opacity: 0.85; }
.btn-outline {
  background: #fff; color: #2C3E50; text-align: center;
  padding: 24rpx; border-radius: 12rpx; font-size: 30rpx;
  border: 2rpx solid #DDD;
}
.btn-outline:active { background: #F5F5F5; }

.tips-section { margin-top: 40rpx; padding: 30rpx; background: #fff; border-radius: 12rpx; }
.tip-title { font-size: 28rpx; font-weight: 600; color: #2C3E50; margin-bottom: 16rpx; }
.tip-item { font-size: 26rpx; color: #888; line-height: 2; }
