.page-container { min-height: 100vh; background: #2C3E50; padding-bottom: 40rpx; }
.loading-state { text-align: center; padding: 200rpx 0; color: #fff; font-size: 28rpx; }
.image-section { width: 100%; position: relative; }
.main-image { width: 100%; height: 600rpx; background: #1a1a1a; }
.toggle-bar { display: flex; justify-content: center; padding: 20rpx; background: rgba(0,0,0,0.5); position: absolute; bottom: 0; left: 0; right: 0; }
.toggle-btn { padding: 14rpx 40rpx; font-size: 26rpx; color: rgba(255,255,255,0.6); border-radius: 30rpx; }
.toggle-btn.active { background: rgba(201,169,110,0.9); color: #fff; font-weight: 500; }
.params-section { margin: 30rpx; padding: 30rpx; background: rgba(255,255,255,0.95); border-radius: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #2C3E50; margin-bottom: 20rpx; }
.param-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.param-item { width: calc(50% - 10rpx); }
.param-label { font-size: 22rpx; color: #999; margin-bottom: 4rpx; }
.param-value { font-size: 26rpx; color: #333; }
.points-cost { margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid #EEE; font-size: 26rpx; color: #999; text-align: right; }
.cost-num { color: #C9A96E; font-weight: 700; }
.action-section { padding: 0 30rpx; }
.action-row { display: flex; gap: 20rpx; margin-bottom: 20rpx; }
.btn-save, .btn-retry { flex: 1; text-align: center; padding: 24rpx; border-radius: 12rpx; font-size: 28rpx; }
.btn-save { background: #C9A96E; color: #fff; }
.btn-retry { background: rgba(255,255,255,0.15); color: #fff; }
.btn-home { text-align: center; padding: 24rpx; color: rgba(255,255,255,0.6); font-size: 28rpx; }
